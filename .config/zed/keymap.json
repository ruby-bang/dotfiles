// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"context": "Workspace",
		"bindings": {
			// "shift shift": "file_finder::Toggle"
			//
			//
			"alt-!": "terminal_panel::ToggleFocus"
		}
	},

	{
		"context": "(not_editing && ProjectPanel)  ",
		"bindings": {
			"\\": "workspace::ToggleLeftDock"
		}
	},
	{
		"context": "(Editor  || Workspace) && vim_mode == normal ",
		"bindings": {
			"H": "pane::ActivatePreviousItem",
			"L": "pane::ActivateNextItem",
			"ctrl-j": ["workspace::SendKeystrokes", "5 j z z"],
			"ctrl-k": ["workspace::SendKeystrokes", "5 k z z"],
			"\\": "workspace::ToggleLeftDock",
			"ctrl-a": "editor::SelectAll"
		}
	},
	{
		"context": "Editor  && vim_mode == visual ",
		"bindings": {
			"J": "editor::MoveLineDown",
			"K": "editor::MoveLineUp"
		}
	},

	{
		"context": "Editor",
		"bindings": {
			// "j k": ["workspace::SendKeystrokes", "escape"]
			"ctrl-a": ["workspace::SendKeystrokes", "G V g g"]
		}
	}
]
